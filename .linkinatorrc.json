{
  "recurse": true,
  "concurrency": 8,
  "retry": true,
  "retryErrors": true,
  "retryErrorsCount": 3,
  "retryErrorsJitter": 3000,
  "format": "JSON",
  "verbosity": "error",
  "skip": [
    "https://example.org/*",
    "https://example.com/*",
    "https://example-verifier.com/*",
    "https://my.domain.com/*",
    "http://issuer-agent.com/*",
    "https://didcomm.org/*",
    "http://localhost*",
    "https://host.docker.internal*",
    "https://identity.foundation/*",
    "https://www.w3.org/TR/*",
    "https://mvnrepository.com/*",
    "https://blog.cheqd.io/*",
    "https://medium.com/*",
    "https://w3c-ccg.github.io/did-resolution/*"
  ]
}
